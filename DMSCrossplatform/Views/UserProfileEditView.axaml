<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:assists="clr-namespace:Material.Styles.Assists;assembly=Material.Styles"
             xmlns:viewModels="clr-namespace:DMSCrossplatform.ViewModels"
             x:CompileBindings="False"
             x:DataType="viewModels:UserProfileEditViewModel"
             x:Class="DMSCrossplatform.Views.UserProfileEditView">
    <StackPanel Spacing="12">
        <StackPanel>
            <TextBlock Text="{Binding Title}"
                       TextWrapping="Wrap"
                       FontSize="22"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource DmsForegroundBrush}" />
            <TextBox PlaceholderText="Email"
                     MaxLength="50"
                     Text="{Binding User.Email}" />
            <TextBox Text="{Binding User.Phone}"
                     MaxLength="11"
                     PlaceholderText="Телефон" />
            <TextBox Text="{Binding User.SecondName}"
                     MaxLength="32"
                     PlaceholderText="Фамилия" />
            <TextBox Text="{Binding User.FirstName}"
                     MaxLength="32"
                     PlaceholderText="Имя" />
            <TextBox Text="{Binding User.ThirdName}"
                     MaxLength="32"
                     PlaceholderText="Отчество" />
        </StackPanel>

        <ComboBox ItemsSource="{Binding Roles}"
                  SelectedItem="{Binding SelectedRole, Mode=TwoWay}"
                  assists:ComboBoxAssist.Label="Выберите должность"
                  Width="200">
            <ComboBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding Name}"
                               Padding="8,4" />
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>

        <ComboBox IsVisible="{Binding CanSeeUnits}"
                  ItemsSource="{Binding Units}"
                  SelectedItem="{Binding SelectedUnit, Mode=TwoWay}"
                  assists:ComboBoxAssist.Label="Выберите отдел"
                  Width="200">
            <ComboBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding Name}"
                               Padding="8,4" />
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>

        <TextBox PlaceholderText="Пароль"
                 MaxLength="50"
                 assists:TextFieldAssist.Hints="Пароль доступен только для записи."
                 Classes="revealPasswordButton"
                 Text="{Binding Password}"
                 PasswordChar="•" />

        <Button IsEnabled="{Binding !IsBusy}"
                Margin="0, 10"
                Command="{Binding SaveCommand}"
                Content="Сохранить пользователя" />

        <TextBlock Text="{Binding ErrorMessage}"
                   Foreground="{DynamicResource DmsErrorBrush}"
                   TextWrapping="Wrap"
                   IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
        <TextBlock Text="{Binding SuccessMessage}"
                   TextWrapping="Wrap"
                   Foreground="{DynamicResource DmsPrimaryBrush}"
                   IsVisible="{Binding SuccessMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
    </StackPanel>
</UserControl>
