<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:DMSCrossplatform.ViewModels"
             xmlns:avalonia="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             xmlns:views="clr-namespace:DMSCrossplatform.Views"
             x:CompileBindings="False"
             
             x:DataType="vm:DocumentViewModel"
             x:Class="DMSCrossplatform.Views.DocumentView">

<Grid RowDefinitions="Auto,*"  Margin="16">
        <!-- Заголовок и кнопки действий -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,16">
            <Button Grid.Column="0" Command="{Binding BackCommand}" Classes="flat">
                <avalonia:MaterialIcon Kind="ArrowLeft" Width="24" Height="24"/>
            </Button>

            <StackPanel Grid.Column="1" Spacing="4" Margin="16,0">
                <TextBlock Text="{Binding Document.Title}"
                           FontSize="20"
                           FontWeight="Bold"/>
                <TextBlock Text="{Binding Document.StatusName}"
                           FontSize="12"
                           Opacity="0.7"/>
            </StackPanel>
            <ScrollViewer Grid.Column="2" HorizontalScrollBarVisibility="Auto">
                <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="{Binding ErrorMessage}" 
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource DmsErrorBrush}"
                           IsVisible="{Binding ErrorMessage,
                           Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                <Button Command="{Binding SubmitForApprovalCommand}"
                        IsVisible="{Binding CanSubmit}"
                        Background="{DynamicResource DmsPrimaryBrush}">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <avalonia:MaterialIcon Kind="Send" Width="18" Height="18"/>
                        <TextBlock Text="Отправить на согласование"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding UploadNewVersionCommand}"
                        IsVisible="{Binding CanUploadVersion}"
                        Background="#4CAF50">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <avalonia:MaterialIcon Kind="ProgressUpload" Width="18" Height="18"/>
                        <TextBlock TextWrapping="Wrap" Text="Загрузить новую версию"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding ApproveCommand}"
                        IsVisible="{Binding CanApprove}"
                        Background="#4CAF50">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <avalonia:MaterialIcon Kind="Check" Width="18" Height="18"/>
                        <TextBlock Text="Согласовать"/>
                    </StackPanel>
                </Button>

                <Button Command="{Binding RequestRejectCommand}"
                        IsVisible="{Binding CanReject}"
                        Background="#F44336">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <avalonia:MaterialIcon Kind="Close" Width="18" Height="18"/>
                        <TextBlock Text="Отклонить"/>
                    </StackPanel>
                </Button>
            </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Вкладки: Просмотр и Согласование -->
        <TabControl MaxWidth="700" Grid.Row="1" SelectedIndex="{Binding SelectedTabIndex}">
            <!-- Вкладка "Просмотр" -->
            <TabItem Header="Просмотр">
                <Grid RowDefinitions="Auto,*">
                    <!-- Выбор версии -->
                    <ScrollViewer HorizontalScrollBarVisibility="Auto">
                        <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,0,0,12">
                        <TextBlock Text="Версия:" VerticalAlignment="Center" FontWeight="Medium"/>
                        <ComboBox ItemsSource="{Binding Versions}"
                                  SelectedItem="{Binding SelectedVersion}"
                                  MinWidth="200">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="{Binding VersionNumber, StringFormat='Версия {0}'}"/>
                                        <TextBlock Text="{Binding CreatedAt, StringFormat='dd.MM.yyyy HH:mm'}"
                                                   FontSize="11"
                                                   Opacity="0.7"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <StackPanel Margin="0,12,0,12"  Spacing="8" IsVisible="{Binding CanDownload}" Orientation="Horizontal">
                            <Button Command="{Binding DownloadCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Скачать"></TextBlock>
                                    <avalonia:MaterialIcon Kind="Download"></avalonia:MaterialIcon>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding ShareCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Поделиться"></TextBlock>
                                    <avalonia:MaterialIcon Kind="Share"></avalonia:MaterialIcon>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                    </ScrollViewer>

                    <!-- Просмотр PDF -->
                    <Border Grid.Row="1"
                            BorderBrush="{DynamicResource MaterialDividerBrush}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Background="{DynamicResource DmsSurfaceBrush}">
                        <views:PdfControl PdfUrl="{Binding PdfUrl}"/>
                    </Border>
                </Grid>
            </TabItem>

            <!-- Вкладка "Согласование" -->
            <TabItem Header="Согласование">
                <Grid RowDefinitions="*,Auto">
                    <!-- Граф согласования -->
                    <ScrollViewer Grid.Row="0"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto">
                        <StackPanel Spacing="16" Margin="16">
                            <TextBlock Text="Маршрут согласования"
                                       FontSize="18"
                                       FontWeight="SemiBold"/>

                            <views:ApprovalGraphView GraphData="{Binding DocumentRouteGraph}"
                                                     Document="{Binding Document}"
                                                     ApprovalHistory="{Binding ApprovalHistory}"/>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- История согласований -->
                    <Border Grid.Row="1"
                            BorderBrush="{DynamicResource MaterialDividerBrush}"
                            BorderThickness="0,1,0,0"
                            Padding="16"
                            MaxHeight="200">
                        <StackPanel Spacing="8">
                            <TextBlock Text="История согласований"
                                       FontWeight="SemiBold"/>

                            <ScrollViewer MaxHeight="150">
                                <ItemsControl ItemsSource="{Binding ApprovalHistory}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="{DynamicResource MaterialDividerBrush}"
                                                    BorderThickness="0,0,0,1"
                                                    Padding="8">
                                                <Grid ColumnDefinitions="Auto,*,Auto">
                                                    <avalonia:MaterialIcon Grid.Column="0"
                                                                           Kind="{Binding IsApproved, Converter={StaticResource ApprovalToIconConverter}}"
                                                                           Width="20"
                                                                           Height="20"
                                                                           Foreground="{Binding IsApproved, Converter={StaticResource ApprovalToColorConverter}}"/>

                                                    <StackPanel Grid.Column="1" Spacing="2" Margin="12,0">
                                                        <TextBlock Text="{Binding ApproverEmail}" FontWeight="Medium"/>
                                                        <TextBlock Text="{Binding StepIndex, Converter={StaticResource AddOneConverter}, StringFormat='Этап: {0:N0}'}"
                                                                   FontSize="11"
                                                                   Opacity="0.7"/>
                                                    </StackPanel>

                                                    <TextBlock Grid.Column="2"
                                                               Text="{Binding CreatedAt, StringFormat='dd.MM.yyyy HH:mm'}"
                                                               FontSize="11"
                                                               Opacity="0.7"
                                                               VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Диалог выбора маршрута -->

        <Border  Grid.Row="0" Grid.RowSpan="2" 
                 IsVisible="{Binding ShowRouteSelector}"
                 Background="#80000000">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                <Border Background="{DynamicResource DmsSurfaceBrush}"
                        BorderBrush="{DynamicResource MaterialDividerBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="24"
                        MaxWidth="600"
                        MaxHeight="500"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                <Grid RowDefinitions="Auto,*,Auto,Auto">
                    <TextBlock Grid.Row="0"
                               Text="Выберите маршрут согласования"
                               FontSize="18"
                               FontWeight="Bold"
                               Margin="0,0,0,16"/>

                    <Grid Grid.Row="1" ColumnDefinitions="*,300">
                        <!-- Список маршрутов -->
                        <ListBox Grid.Column="0"
                                 ItemsSource="{Binding AvailableRoutes}"
                                 SelectedItem="{Binding SelectedRoute}"
                                 Margin="0,0,16,0">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}" Padding="8"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <!-- Превью маршрута -->
                        <Border Grid.Column="1"
                                BorderBrush="{DynamicResource MaterialDividerBrush}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="8">
                            <ScrollViewer>
                                <views:RouteGraphView DataContext="{Binding SelectedSubmitRouteGraph}"
                                                      IsEditorMode="True"/>
                            </ScrollViewer>
                        </Border>
                    </Grid>

                    <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="12"
                                HorizontalAlignment="Right"
                                Margin="0,16,0,0">
                        <Button Command="{Binding CancelSubmitCommand}" Classes="flat">
                            <TextBlock Text="Отмена"/>
                        </Button>
                        <Button Command="{Binding ConfirmSubmitCommand}"
                                IsEnabled="{Binding SelectedRoute, Converter={x:Static ObjectConverters.IsNotNull}}"
                                Background="{DynamicResource DmsPrimaryBrush}">
                            <TextBlock Text="Отправить"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
            </ScrollViewer>
        </Border>

        <!-- Диалог причины отклонения -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                IsVisible="{Binding ShowRejectDialog}"
                Background="#80000000">
            <Border Background="{DynamicResource DmsSurfaceBrush}"
                    BorderBrush="{DynamicResource MaterialDividerBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="24"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel Spacing="16">
                    <TextBlock Text="Причина отклонения"
                               FontSize="18"
                               FontWeight="Bold"/>

                    <TextBox Text="{Binding RejectComment}"
                             AcceptsReturn="True"
                             MinHeight="110"
                             TextWrapping="Wrap"
                             PlaceholderText="Укажите причину отклонения"/>

                    <StackPanel Orientation="Horizontal"
                                Spacing="12"
                                HorizontalAlignment="Right">
                        <Button Command="{Binding CancelRejectCommand}"
                                Classes="flat">
                            <TextBlock Text="Отмена"/>
                        </Button>
                        <Button Command="{Binding ConfirmRejectCommand}"
                                IsEnabled="{Binding RejectComment, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                Background="#F44336">
                            <TextBlock Text="Отклонить"/>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>
        
        <!---Поделится QR-кодом-->
        <Border Grid.Row="0" Grid.RowSpan="2"
                IsVisible="{Binding ShowShareQr}"
                Background="#80000000">
            <Border Background="{DynamicResource DmsSurfaceBrush}"
                    BorderBrush="{DynamicResource MaterialDividerBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="24"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <Border>
                    <StackPanel>
                        <Image Source="{Binding QrCodeBitmap}"  Width="200" Height="200"></Image>
                        <StackPanel Orientation="Horizontal">
                            <Button Command="{Binding CancelShareCommand}"
                                    Classes="flat">
                                <TextBlock Text="Отмена"/>
                            </Button>
                            <Button Command="{Binding DownloadQrCommand}" Classes="flat">
                                <TextBlock Text="Скачать QR"/>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                    
                </Border>
            </Border>
            
            </Border>
    </Grid>

</UserControl>
