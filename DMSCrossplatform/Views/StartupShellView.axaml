<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:DMSCrossplatform.ViewModels"
             x:DataType="vm:StartupShellViewModel"
             
             x:Class="DMSCrossplatform.Views.StartupShellView">
    <ContentControl Content="{Binding Region.CurrentViewModel}" />
</UserControl>
