<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:assists="clr-namespace:Material.Styles.Assists;assembly=Material.Styles"
             xmlns:avalonia="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             xmlns:viewModels="clr-namespace:DMSCrossplatform.ViewModels"
             x:CompileBindings="False"
             x:DataType="viewModels:UnitEditViewModel"
             x:Class="DMSCrossplatform.Views.UnitEditView">
    <StackPanel IsVisible="{Binding CanSeeUnits}" Spacing="12">
        <StackPanel Orientation="Horizontal">
            <ComboBox ItemsSource="{Binding Units}"
                      SelectedItem="{Binding SelectedUnit, Mode=TwoWay}"
                      assists:ComboBoxAssist.Label="Выберите отдел"
                      Width="200">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Name}"
                                   Padding="8,4" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <StackPanel>
                <Button Classes="flat" Command="{Binding AddCommand}">
                    <avalonia:MaterialIcon Kind="Add" />
                </Button>
                <Button Classes="flat" Command="{Binding EditCommand}">
                    <avalonia:MaterialIcon Kind="Edit" />
                </Button>
            </StackPanel>
        </StackPanel>

        <TextBox PlaceholderText="Отдел"
                 Text="{Binding Unit, UpdateSourceTrigger=PropertyChanged}" />
        <Button IsEnabled="{Binding !IsBusy}"
                Margin="0,24"
                Command="{Binding SaveCommand}"
                Content="Сохранить отдел" />

        <TextBlock Text="{Binding ErrorMessage}"
                   Foreground="{DynamicResource DmsErrorBrush}"
                   TextWrapping="Wrap"
                   IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
        <TextBlock Text="{Binding SuccessMessage}"
                   TextWrapping="Wrap"
                   Foreground="{DynamicResource DmsPrimaryBrush}"
                   IsVisible="{Binding SuccessMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
    </StackPanel>
</UserControl>
