<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:DMSCrossplatform.Views"
             xmlns:controls="clr-namespace:DMSCrossplatform.Pdf.Controls"
             xmlns:global="clr-namespace:"
             x:Class="DMSCrossplatform.Views.PdfControl">

    <Grid>
        <controls:PdfViewerControl Name="PdfContainer"/>

        <TextBlock Text="Загрузка PDF..."
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Name="LoadingText"
                   Opacity="0.7"/>
    </Grid>
</UserControl>
