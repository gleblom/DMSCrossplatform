<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:assists="clr-namespace:Material.Styles.Assists;assembly=Material.Styles"
             xmlns:avalonia="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             xmlns:custom="clr-namespace:DMSCrossplatform.Views.Custom"
             xmlns:viewModels="clr-namespace:DMSCrossplatform.ViewModels"
             x:CompileBindings="False"
             x:DataType="viewModels:RoleEditViewModel"
             x:Class="DMSCrossplatform.Views.RoleEditView">
    <StackPanel IsVisible="{Binding CanSeeUnits}" Spacing="12">
        <StackPanel Orientation="Horizontal">
            <ComboBox ItemsSource="{Binding Roles}"
                      SelectedItem="{Binding SelectedRole, Mode=TwoWay}"
                      assists:ComboBoxAssist.Label="Выберите должность"
                      Width="200">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Name}"
                                   Padding="8,4" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <StackPanel>
                <Button Classes="flat" Command="{Binding AddCommand}">
                    <avalonia:MaterialIcon Kind="Add" />
                </Button>
                <Button Classes="flat" Command="{Binding EditCommand}">
                    <avalonia:MaterialIcon Kind="Edit" />
                </Button>
            </StackPanel>
        </StackPanel>

        <TextBox Margin="0,10"
                 PlaceholderText="Название должности"
                 Text="{Binding Role, UpdateSourceTrigger=PropertyChanged}" />
        <TextBlock TextWrapping="Wrap"
                   Text="Выберите категории с которыми может работать должность" />
        <Border>
            <custom:MultiSelectComboBoxView Margin="0, 10"
                                            DataContext="{Binding Categories}"
                                            Width="150" />
        </Border>
        <Button IsEnabled="{Binding !IsBusy}"
                Margin="0, 10"
                Command="{Binding SaveCommand}"
                Content="Сохранить должность" />

        <TextBlock Text="{Binding ErrorMessage}"
                   Foreground="{DynamicResource DmsErrorBrush}"
                   TextWrapping="Wrap"
                   IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
        <TextBlock Text="{Binding SuccessMessage}"
                   TextWrapping="Wrap"
                   Foreground="{DynamicResource DmsPrimaryBrush}"
                   IsVisible="{Binding SuccessMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
    </StackPanel>
</UserControl>
