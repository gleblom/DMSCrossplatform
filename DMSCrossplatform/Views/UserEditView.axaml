<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewModels="clr-namespace:DMSCrossplatform.ViewModels"
             x:CompileBindings="False"
             x:DataType="viewModels:UserEditViewModel"
             x:Class="DMSCrossplatform.Views.UserEditView">
    <Grid Background="{DynamicResource DmsSurfaceBrush}" MaxHeight="560">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Border Padding="24"
                    MaxWidth="350"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Background="{DynamicResource DmsSurfaceColor}">
                <StackPanel Spacing="12">
                    <ContentControl Content="{Binding UserProfile}" />
                    <ContentControl Content="{Binding RoleEditor}" />
                    <ContentControl Content="{Binding UnitEditor}" />
                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</UserControl>
