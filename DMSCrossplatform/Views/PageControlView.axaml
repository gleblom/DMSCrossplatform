<ContentPage xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewModels="clr-namespace:DMSCrossplatform.ViewModels"
             x:CompileBindings="False"
             x:DataType="viewModels:PageControlViewModel"
             x:Class="DMSCrossplatform.Views.PageControlView">
   <ContentControl Content="{Binding ActiveView}"></ContentControl>
</ContentPage>
