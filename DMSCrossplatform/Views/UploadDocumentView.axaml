<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:CompileBindings="False"
             x:DataType="viewModels:UploadDocumentViewModel"
             xmlns:controls="clr-namespace:Material.Styles.Controls;assembly=Material.Styles"
             xmlns:avalonia="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             xmlns:assists="clr-namespace:Material.Styles.Assists;assembly=Material.Styles"
             xmlns:viewModels="clr-namespace:DMSCrossplatform.ViewModels"
             x:Class="DMSCrossplatform.Views.UploadDocumentView">
        <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition MaxWidth="400" Width="3*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
        <!-- Заголовок -->
        <Border Grid.Row="0"   Grid.Column="1"
                Height="60"
                VerticalAlignment="Top">
            <TextBlock Text="Загрузка документа"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       FontSize="20"
                       FontWeight="Bold"/>
        </Border>

        <!-- Основной контент -->
        <ScrollViewer Grid.Row="1" Grid.Column="1"
                      VerticalScrollBarVisibility="Hidden"
                      Margin="16">

            <StackPanel Spacing="20">
                
                <!-- Название документа -->
                <controls:Card Padding="16" >
                    <StackPanel Spacing="8">
                        <TextBlock Text="Название документа"
                                   FontWeight="SemiBold"
                                   FontSize="16"/>
                        <TextBox 
                            assists:TextFieldAssist.Label="Введите название"

                            MaxLength="20"
                            Text="{Binding DocumentTitle, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                            Width="300"/>
                    </StackPanel>
                </controls:Card>

                <!-- Категория -->
                <controls:Card Padding="16" >
                    <StackPanel Spacing="8">
                        <TextBlock Text="Категория документа"
                                   FontWeight="SemiBold"
                                   FontSize="16"/>
                        <ComboBox ItemsSource="{Binding Categories}"
                                  SelectedItem="{Binding SelectedFileCategory, Mode=TwoWay}"
                                  assists:ComboBoxAssist.Label="Выберите категорию"
                                  Width="300">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}" 
                                               Padding="8,4"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                </controls:Card>

                <!-- Выбор файла -->
                <controls:Card Padding="16" >
                    <StackPanel Spacing="16">
                        <TextBlock Text="Файл документа"
                                   FontWeight="SemiBold"
                                   FontSize="16"/>
                        
                        <Border BorderThickness="2"
                                CornerRadius="8"
                                Padding="40"
                                Background="{DynamicResource MaterialDesignPaper}"
                                Height="250">
                            <StackPanel HorizontalAlignment="Center" 
                                        VerticalAlignment="Center"
                                        Spacing="12">
                                <avalonia:MaterialIcon 
                                    Kind="FileDocumentOutline"
                                    Width="48"
                                    Height="48"/>
                                
                                <TextBlock Text="Выберите файл документа"
                                           HorizontalAlignment="Center"
                                           FontSize="16"
                                           TextAlignment="Center"
                                           Foreground="#333"/>
                                
                                <Button Content="Выбрать файл"
                                        Command="{Binding SelectFileCommand}"
                                        HorizontalAlignment="Center"
                                        Padding="24,12">
                                </Button>
                                
                                <!-- Выбранный файл -->
                                <Border IsVisible="{Binding SelectedFileNameVisbility}"
                                        CornerRadius="4"
                                        Padding="12"
                                        Margin="0,8,0,0">
                                    <StackPanel Orientation="Horizontal" 
                                                Spacing="8"
                                                VerticalAlignment="Center">
                                        <avalonia:MaterialIcon 
                                            Kind="FileCheck"
                                            Width="20"
                                            Foreground="{DynamicResource DmsPrimaryBrush}"
                                            Height="20"/>
                                        <TextBlock Text="{Binding SelectedFileName, Mode=TwoWay}"
                                                   TextAlignment="Center"
                                                   FontSize="14"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxWidth="200"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                        
                    </StackPanel>
                </controls:Card>
            </StackPanel>
        </ScrollViewer>

        <!-- Кнопка загрузки -->
        <Border Grid.Row="2"   Grid.Column="1"
                BorderThickness="1,0,0,0"
                Padding="16">
            <StackPanel Orientation="Horizontal" 
                        HorizontalAlignment="Center"
                        Spacing="12">
                
                <Button Content="Загрузить документ"
                        Command="{Binding SubmitCommand}"
                        IsEnabled="{Binding IsEnabled}"
                        Padding="24,12"
                        MinWidth="180">
                </Button>
            </StackPanel>
        </Border>
        
        <!-- Индикатор загрузки -->
        <Border Grid.Row="0" Grid.RowSpan="3"  Grid.Column="1"
                IsVisible="{Binding IsLoading}"
                Background="#80000000"

                ZIndex="1000">
            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Spacing="16">
                <ProgressBar Width="50" Height="50"
                             IsIndeterminate="True"
                              Classes="circular"
                              IsVisible="{Binding IsLoading}"/>
                <TextBlock Text="Загрузка..."
                           FontSize="16"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
