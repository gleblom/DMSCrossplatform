<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:DMSCrossplatform.ViewModels"
             xmlns:avalonia="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             xmlns:views="clr-namespace:DMSCrossplatform.Views"
             xmlns:dto="clr-namespace:DMSCrossplatform.Models.Dto"
             x:CompileBindings="False"
             x:DataType="vm:ApprovalRouteEditorViewModel"
             x:Class="DMSCrossplatform.Views.ApprovalRouteEditorView">

    <Grid RowDefinitions="Auto,*,Auto" Margin="16">
        <!-- Заголовок -->
        <StackPanel Grid.Row="0" Spacing="12" Margin="0,0,0,16">
            <TextBlock Text="{Binding RouteId, Converter={x:Static ObjectConverters.IsNull},
                             ConverterParameter='Создание маршрута|Редактирование маршрута'}"
                       FontSize="24"
                       FontWeight="Bold"/>

            <TextBox Text="{Binding RouteName}"
                     PlaceholderText="Название маршрута"
                     Width="400"
                     HorizontalAlignment="Left"/>
        </StackPanel>

        <!-- Основной контент: конструктор + превью -->
        <Grid Grid.Row="1" ColumnDefinitions="*,400" ColumnSpacing="16" IsVisible="{Binding !IsLoading}">
            <!-- Конструктор этапов -->
            <Border Grid.Column="0"
                    BorderBrush="{DynamicResource MaterialDividerBrush}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="16">
                <Grid RowDefinitions="Auto,*,Auto">
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12" Margin="0,0,0,12">
                        <TextBlock Text="Этапы согласования"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                        <Button Command="{Binding AddStepCommand}"
                                Background="{DynamicResource DmsPrimaryBrush}">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <avalonia:MaterialIcon Kind="Plus" Width="18" Height="18"/>
                                <TextBlock Text="Добавить этап"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <ScrollViewer Grid.Row="1">
                        <ItemsControl ItemsSource="{Binding Steps}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:RouteStepViewModel">
                                    <Border BorderBrush="{DynamicResource MaterialDividerBrush}"
                                            BorderThickness="1"
                                            CornerRadius="4"
                                            Padding="12"
                                            Margin="0,0,0,8"
                                            Background="{DynamicResource DmsSurfaceBrush}">
                                        <Grid RowDefinitions="Auto,Auto,Auto,Auto" ColumnDefinitions="*,Auto">
                                            <!-- Заголовок этапа -->
                                            <TextBlock Grid.Row="0" Grid.Column="0"
                                                       Text="{Binding StepIndex, StringFormat='Этап {0}'}"
                                                       FontWeight="Medium"
                                                       Margin="0,0,0,8"/>

                                            <!-- Кнопки управления -->
                                            <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Spacing="4">
                                                <Button Command="{Binding $parent[ItemsControl].((vm:ApprovalRouteEditorViewModel)DataContext).MoveStepUpCommand}"
                                                        CommandParameter="{Binding}"
                                                        Classes="flat"
                                                        Padding="4">
                                                    <avalonia:MaterialIcon Kind="ArrowUp" Width="16" Height="16"/>
                                                </Button>
                                                <Button Command="{Binding $parent[ItemsControl].((vm:ApprovalRouteEditorViewModel)DataContext).MoveStepDownCommand}"
                                                        CommandParameter="{Binding}"
                                                        Classes="flat"
                                                        Padding="4">
                                                    <avalonia:MaterialIcon Kind="ArrowDown" Width="16" Height="16"/>
                                                </Button>
                                                <Button Command="{Binding $parent[ItemsControl].((vm:ApprovalRouteEditorViewModel)DataContext).RemoveStepCommand}"
                                                        CommandParameter="{Binding}"
                                                        Classes="flat"
                                                        Padding="4">
                                                    <avalonia:MaterialIcon Kind="Delete" Width="16" Height="16"/>
                                                </Button>
                                            </StackPanel>

                                            <!-- Выбор отдела -->
                                            <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                                       Text="Отдел:"
                                                       FontSize="12"
                                                       Opacity="0.7"
                                                       Margin="0,0,0,4"/>

                                            <ComboBox Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                                      ItemsSource="{Binding $parent[ItemsControl].((vm:ApprovalRouteEditorViewModel)DataContext).Units}"
                                                      SelectedItem="{Binding SelectedUnit}"
                                                      PlaceholderText="Выберите отдел"
                                                      Margin="0,0,0,8">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Name}"/>
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>

                                            <!-- Выбор сотрудника -->
                                            <ComboBox Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                                                      ItemsSource="{Binding FilteredUsers}"
                                                      SelectedItem="{Binding SelectedUser}"
                                                      PlaceholderText="Выберите согласующего"
                                                      IsEnabled="{Binding !!SelectedUnit}">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate DataType="dto:UserFullDto">
                                                        <StackPanel Spacing="2">
                                                            <TextBlock Text="{Binding FullName}" FontWeight="Medium"/>
                                                            <TextBlock Text="{Binding Email}" FontSize="11" Opacity="0.7"/>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <TextBlock Grid.Row="2"
                               Text="{Binding Steps.Count, StringFormat='Всего этапов: {0}'}"
                               FontSize="12"
                               Opacity="0.7"
                               Margin="0,12,0,0"/>
                </Grid>
            </Border>

            <!-- Превью маршрута -->
            <Border Grid.Column="1"
                    BorderBrush="{DynamicResource MaterialDividerBrush}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="16">
                <Grid RowDefinitions="Auto,*">
                    <TextBlock Grid.Row="0"
                               Text="Предпросмотр"
                               FontWeight="SemiBold"
                               Margin="0,0,0,12"/>

                    <ScrollViewer Grid.Row="1"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto">
                        <views:RouteGraphView DataContext="{Binding RouteGraph}"
                                              IsEditorMode="True"/>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- Кнопки действий -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="12" Margin="0,16,0,0"
                    HorizontalAlignment="Right">
            <Button Command="{Binding CancelCommand}"
                    Classes="flat">
                <TextBlock Text="Отмена"/>
            </Button>
            <Button Command="{Binding SaveCommand}"
                    IsEnabled="{Binding !IsSaving}"
                    Background="{DynamicResource DmsPrimaryBrush}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <avalonia:MaterialIcon Kind="ContentSave" Width="18" Height="18"
                                           IsVisible="{Binding !IsSaving}"/>
                    <ProgressBar IsIndeterminate="True" Width="18" Height="18"
                                 IsVisible="{Binding IsSaving}"/>
                    <TextBlock Text="Сохранить"/>
                </StackPanel>
            </Button>
        </StackPanel>

        <!-- Индикатор загрузки -->
        <Grid Grid.Row="1" IsVisible="{Binding IsLoading}"
              HorizontalAlignment="Center"
              VerticalAlignment="Center">
            <StackPanel Spacing="12" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200"/>
                <TextBlock Text="Загрузка..."
                           HorizontalAlignment="Center"
                           Opacity="0.7"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
