<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light">
            <Color x:Key="DmsPrimaryColor">#78B24B</Color>
            <Color x:Key="DmsBackgroundColor">#FFFFFF</Color>
            <Color x:Key="DmsSurfaceColor">#F5F7F4</Color>
            <Color x:Key="DmsForegroundColor">#1F1F1F</Color>
            <Color x:Key="DmsErrorColor">#D32F2F</Color>
            <SolidColorBrush x:Key="DataGridRowSelectedUnfocusedBackgroundColor" Color="#78B24B" />
            <SolidColorBrush x:Key="DataGridRowSelectedBackgroundColor" Color="#78B24B" />
            <LinearGradientBrush x:Key="LinearGradientBackgroundBrush" StartPoint="100%,300%" EndPoint="0%,0%">
                <GradientStop Color="{DynamicResource DmsPrimaryColor}" Offset="0" />
                <GradientStop Color="{DynamicResource DmsBackgroundColor}" Offset="1" />
            </LinearGradientBrush>
            <SolidColorBrush x:Key="DmsPrimaryBrush" Color="{DynamicResource DmsPrimaryColor}"/>
            <SolidColorBrush x:Key="DmsBackgroundBrush" Color="{DynamicResource DmsBackgroundColor}"/>
            <SolidColorBrush x:Key="DmsSurfaceBrush" Color="{DynamicResource DmsSurfaceColor}"/>
            <SolidColorBrush x:Key="DmsForegroundBrush" Color="{DynamicResource DmsForegroundColor}"/>
            <SolidColorBrush x:Key="DmsErrorBrush" Color="{DynamicResource DmsErrorColor}"/>
        </ResourceDictionary>
        <ResourceDictionary x:Key="Dark">
            <Color x:Key="DmsPrimaryColor">#78B24B</Color>
            <Color x:Key="DmsBackgroundColor">#1E1E1E</Color>
            <Color x:Key="DmsSurfaceColor">#2A2A2A</Color>
            <Color x:Key="DmsForegroundColor">#EDEDED</Color>
            <Color x:Key="DmsErrorColor">#FF6B6B</Color>
            <LinearGradientBrush x:Key="LinearGradientBackgroundBrush" StartPoint="100%,300%" EndPoint="0%,0%">
                <GradientStop Color="{DynamicResource DmsPrimaryColor}" Offset="0" />
                <GradientStop Color="{DynamicResource DmsBackgroundColor}" Offset="1" />
            </LinearGradientBrush>
            <SolidColorBrush x:Key="DmsPrimaryBrush" Color="{DynamicResource DmsPrimaryColor}"/>
            <SolidColorBrush x:Key="DmsBackgroundBrush" Color="{DynamicResource DmsBackgroundColor}"/>
            <SolidColorBrush x:Key="DmsSurfaceBrush" Color="{DynamicResource DmsSurfaceColor}"/>
            <SolidColorBrush x:Key="DmsForegroundBrush" Color="{DynamicResource DmsForegroundColor}"/>
            <SolidColorBrush x:Key="DmsErrorBrush" Color="{DynamicResource DmsErrorColor}"/>
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>
</ResourceDictionary>
