    <ItemGroup>
      <Reference Include="Mono.Android">
        <HintPath>..\..\..\..\..\Program Files\dotnet\packs\Microsoft.Android.Ref.36\36.1.43\ref\net10.0\Mono.Android.dll</HintPath>
      </Reference>
