        <PackageReference Include="Microsoft.Extensions.Logging" />
        <PackageReference Include="Newtonsoft.Json" />
        <PackageReference Include="NLog" />
        <PackageReference Include="NLog.Extensions.Logging" />
        <PackageReference Include="Plugin.LocalNotification" />
        <PackageReference Include="QRCoder" />
        <PackageReference Include="SkiaSharp" />
        <PackageReference Include="SkiaSharp.NativeAssets.Win32" />
        <PackageReference Include="System.Security.Cryptography.ProtectedData" />
        <PackageReference Include="Xaml.Behaviors.Avalonia" />
    </ItemGroup>

    <ItemGroup>
      <Compile Update="Views\Custom\MultiSelectComboBoxView.axaml.cs">
        <DependentUpon>MultiSelectComboBox.axaml</DependentUpon>
